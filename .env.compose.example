# Переменные для подстановки в docker-compose.yaml (${VAR}).
# Скопируйте в .env в корне проекта:
#   cp .env.compose.example .env

# Профиль compose: dev (hot-reload) или prod (nginx + workers)
COMPOSE_PROFILES=dev

MYSQL_CONTAINER_NAME=mysql-asterisk
MYSQL_PORT=3306

# Пустое значение — API через тот же origin (nginx на :80)
# Для прямого доступа к Vite (:5173) укажите http://127.0.0.1:8000
VITE_API_BASE_URL=
