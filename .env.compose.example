# Переменные для подстановки в docker-compose.yaml (${VAR}).
# Скопируйте в .env в корне проекта:
#   cp .env.compose.example .env

# Профиль compose: dev (hot-reload) или prod (workers + сборка static)
COMPOSE_PROFILES=dev

MYSQL_CONTAINER_NAME=mysql-asterisk
MYSQL_PORT=3306

# Prod (nginx :80): /api — REST /api/instances/, WS /api/ws/instances
# Пустое значение при сборке frontend-prod тоже нормализуется в /api
# Dev без nginx (Vite :5173): http://127.0.0.1:8000
VITE_API_BASE_URL=/api
