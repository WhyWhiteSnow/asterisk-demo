# Переменные LDAP-сервисов (openldap, phpldapadmin) и LDAP-клиента FastAPI.
# Скопируйте в .env.ldap:
#   cp .env.ldap.example .env.ldap

# openldap
LDAP_LOG_LEVEL=256
LDAP_ORGANISATION=planeta Inc.
LDAP_DOMAIN=planeta.ru
LDAP_BASE_DN=dc=planeta,dc=ru
LDAP_ADMIN_PASSWORD=admin
LDAP_CONFIG_PASSWORD=admin
LDAP_READONLY_USER=false
LDAP_TLS=false

# phpldapadmin
PHPLDAPADMIN_LDAP_HOSTS=openldap
PHPLDAPADMIN_HTTPS=false

# fastapi ldap client
LDAP_ENABLED=true
LDAP_SERVER=openldap
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_USER_DN_TEMPLATE=uid={username},ou=users,{base_dn}
LDAP_ADMIN_DN=cn=admin,dc=planeta,dc=ru
LDAP_SEARCH_BASE=ou=users,dc=planeta,dc=ru
LDAP_SEARCH_FILTER=(uid={username})
