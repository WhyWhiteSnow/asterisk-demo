# Переменные контейнеров fastapi-dev / fastapi-prod.
# Скопируйте в .env.fastapi:
#   cp .env.fastapi.example .env.fastapi

DEV_MODE=true
# Должен соответствовать COMPOSE_PROFILES в .env: true → dev, false → prod
HOSTNAME=localhost
DB_HOSTNAME=mysql-asterisk
# MYSQL_* — в .env.mysql; MYSQL_PORT и MYSQL_CONTAINER_NAME — в .env
MYSQL_CDR_TABLE=asterisk_cdr

ASTERISK_UID=1000
ASTERISK_GID=1000
ASTERISK_IMAGE_TAG=my-asterisk:v1.0
# Сборка образа: deploy/docker/asterisk.Dockerfile (см. app/utils/asterisk_image.py)
ASTERISK_IMAGE_PATH=.

PROJECT_PATH=/app
# Абсолютный путь проекта на хосте. Обязателен в prod: Asterisk-контейнеры монтируют
# HOST_PROJECT_PATH/asterisk_configs/{name}. Должен совпадать с каталогом, откуда запускается docker compose.
HOST_PROJECT_PATH=/home/student/asterisk-demo/ceph-asterisk
CONFIG_FOLDER=asterisk_configs
COMPOSE_FOLDER=docker-compose
# Контейнер nginx (HTTP + SIP stream), см. docker-compose service front
NGINX_CONTAINER_NAME=nginx_12

ASTERISK_ODBC_ID=asterisk_cdr
DSN=asterisk-connector
PJSIP_EXTERNAL_ADDRESS=212.49.119.138
PJSIP_LOCAL_NETS=172.17.0.0/16,172.18.0.0/16,127.0.0.1/32

SECRET_KEY=your-secret-key-change-in-production
REFRESH_SECRET_KEY=refreshsecretkey

# Пользователь, создаваемый при старте приложения (если ещё не существует)
DEFAULT_ADMIN_LOGIN=admin
DEFAULT_ADMIN_PASSWORD=admin
DEFAULT_ADMIN_NAME=Administrator
# LDAP_* — в .env.ldap
