# Переменные для подстановки в docker-compose.yaml (${VAR}).
# Скопируйте в .env в корне проекта (именно .env — compose читает его автоматически):
#   cp .env.compose.example .env

# Профиль compose для FastAPI: dev (hot-reload) или prod (workers)
COMPOSE_PROFILES=dev

MYSQL_CONTAINER_NAME=mysql-asterisk
MYSQL_PORT=3306
