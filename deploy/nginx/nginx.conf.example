# Prod: хостовый nginx отдаёт static и проксирует API на FastAPI (:8000).
#
# Перед использованием:
#   docker compose --profile prod up --build
# (frontend-prod соберёт UI в deploy/static/)
#
# 1. sudo cp deploy/nginx/proxy_params /etc/nginx/snippets/asterisk-proxy_params.conf
# 2. sudo cp deploy/nginx/api_locations.inc /etc/nginx/snippets/asterisk-api_locations.inc
# 3. Замените root ниже на абсолютный путь к deploy/static на сервере
# 4. sudo cp deploy/nginx/host-prod.conf.example /etc/nginx/sites-available/asterisk-demo.conf
#    sudo ln -sf /etc/nginx/sites-available/asterisk-demo.conf /etc/nginx/sites-enabled/
#    sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # Раздача фронтенда
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Проксирование API (замените /api/ на ваш реальный префикс, если он отличается)
    location /api/ {
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 10s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;

        # БЕЗ слеша на конце, чтобы бэкенд получил полный путь (например, /api/instances)
        proxy_pass http://fastapi-prod:8000/;
    }
}
